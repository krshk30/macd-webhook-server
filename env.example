PORT=3000

SCHWAB_CLIENT_ID=your_app_key
SCHWAB_CLIENT_SECRET=your_secret
SCHWAB_ACCOUNT_ID=your_account_number
SCHWAB_ACCOUNT_HASH=
SCHWAB_CALLBACK_URL=https://your-app.up.railway.app/auth/callback

WEBHOOK_TOKEN=your_secret_token

DEFAULT_QUANTITY=10
MAX_POSITIONS=3
MAX_DAILY_LOSS=-500
TRADING_START_HOUR=7
TRADING_END_HOUR=18

ORPHAN_TIMEOUT_MINS=5
ENABLE_BROKER_ORPHAN_IMPORT=false
HEARTBEAT_TIMEOUT_SECS=60
DEDUP_WINDOW_MS=5000
PENDING_ENTRY_CHECK_INTERVAL_SECS=2
PENDING_ENTRY_TIMEOUT_SECS=120

LIMIT_BUFFER_CENTS=0.01
HARD_STOP_PCT=0.01
HARD_STOP_MIN_CENTS=0.01
FLOOR_CHECK_INTERVAL_SECS=5
FLOOR_AT_1PCT=0
FLOOR_AT_2PCT=0.5
FLOOR_AT_3PCT=1.5
FLOOR_AT_4PCT=2.5
FLOOR_TRAIL_GAP=1.5
SERVER_MANAGED_SCALES=true
SCALE_PCT2_THRESHOLD=2
SCALE_PCT2_SELL_PCT=50
SCALE_FAST4_THRESHOLD=4
SCALE_FAST4_SELL_PCT=75
SCALE_PCT4_AFTER2_THRESHOLD=4
SCALE_PCT4_AFTER2_SELL_PCT=25

ENABLE_FILE_LOG=true
DISCORD_WEBHOOK_URL=
DATA_DIR=
LOG_DIR=
